<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Basic Sandboxing -->
    <key>com.apple.security.app-sandbox</key>
    <true/>
    
    <!-- File Access - User-selected files are allowed -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
    
    <!-- Network Access - Needed for the local axum server and updates -->
    <key>com.apple.security.network.client</key>
    <true/>
    <key>com.apple.security.network.server</key>
    <true/>
    
    <!-- Hardware Access - Only if needed for camera/mic -->
    <!-- <key>com.apple.security.device.camera</key>
    <true/> -->
    
    <!-- Printing Access - Needed for PDF exports if uses system print dialog -->
    <key>com.apple.security.print</key>
    <true/>
</dict>
</plist>
