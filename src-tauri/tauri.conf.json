{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CineFlow Suite",
  "version": "1.0.3",
  "identifier": "com.exposeu.cineflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CineFlow Suite",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc: http://localhost:*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": { "type": "skip" },
      "nsis": {
        "languages": ["English"],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "installMode": "perMachine"
      }
    },
    "macOS": {
      "entitlements": "entitlements.app.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist",
      "frameworks": [
        "Frameworks/ACFPluginHost.framework",
        "Frameworks/FTF.framework",
        "Frameworks/QtConcurrent.framework",
        "Frameworks/QtCore.framework",
        "Frameworks/QtDBus.framework",
        "Frameworks/QtGui.framework",
        "Frameworks/QtMultimedia.framework",
        "Frameworks/QtMultimediaWidgets.framework",
        "Frameworks/QtNetwork.framework",
        "Frameworks/QtOpenGL.framework",
        "Frameworks/QtPrintSupport.framework",
        "Frameworks/QtQml.framework",
        "Frameworks/QtQuick.framework",
        "Frameworks/QtScript.framework",
        "Frameworks/QtSql.framework",
        "Frameworks/QtWebChannel.framework",
        "Frameworks/QtWidgets.framework",
        "Frameworks/QtXml.framework",
        "Frameworks/QtXmlPatterns.framework",
        "Frameworks/SDL2.framework"
      ]
    },
    "externalBin": [
      "bin/ffmpeg",
      "bin/ffprobe",
      "bin/braw_bridge",
      "bin/REDline"
    ],
    "resources": {
      "bin/BlackmagicRawAPI.dll": ".",
      "libs/": "libs/"
    }
  }
}
