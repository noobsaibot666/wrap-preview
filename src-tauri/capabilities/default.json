{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    {
      "identifier": "opener:allow-reveal-item-in-dir",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    "dialog:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "/Volumes/**"
        }
      ]
    },
    "fs:default",
    "fs:write-all",
    "core:webview:allow-print",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "bin/ffmpeg", "sidecar": true, "args": true },
        { "name": "bin/ffprobe", "sidecar": true, "args": true },
        { "name": "bin/braw_bridge", "sidecar": true, "args": true },
        { "name": "bin/REDline", "sidecar": true, "args": true }
      ]
    }
  ]
}